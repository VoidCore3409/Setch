[package]
name = "setch"
version = "0.1.4"
edition = "2024"
description = "A lightweight, configurable system fetch tool written in Rust"
license = "MIT"
repository = "https://github.com/VoidCore3409/Setch"

[dependencies]
rusqlite = { version = "0.31", features = ["bundled"] }
sysinfo = "0.38.2"
uname = "0.1.1"
owo-colors = "4"
getgpuname = "0.1.0"
nix = { version = "0.31.2", features = ["fs"] }
local-ip-address = "0.6"
jsonc-parser = { version = "0.29", features = ["serde"] }
serde_json = "1.0"
viuer = "0.9"
sys-locale = "0.3.2"
battery = "0.7.8"
raw-cpuid = "11"

[profile.release]
lto = true
opt-level = 3
codegen-units = 1
panic = 'abort'
strip = true
